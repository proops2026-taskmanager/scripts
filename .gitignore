# Session state — ephemeral, never commit
.session-synced

# Local-only directories (each has its own git repo)
# Anchored with / so they only match at repo root, not nested paths like ci/k8s/
/api-gateway/
/task-service/
/user-service/
/frontend-service/
/k8s/
/eks/
/terraform/

# Runtime
logs/
tmp/
*.log

# Node
node_modules/
dist/

# OS
.DS_Store

# Claude Code internal (session-specific, not shared)
SESSION_HANDOVER_STATE.md
PROJECT-MEMORY.md
CRAFT-PROMPT-microservice-docs.md
draft-program/
demo-repository/
collections/
charts/
# e2e-tests tracked — smoke script needed by CI pipeline
# Exception: e2e-tests/smoke/ is the UAT smoke suite (AC-05 — IRD-32)
memory/*
# Exception: git-workflows.md is a shared team doc (AC-01 — IRD-30)
!memory/git-workflows.md
# Exception: github-actions.md is the CI/CD reference doc (AC-08 — IRD-31)
!memory/github-actions.md
# Exception: sonarcloud.md is the quality gate reference doc (AC-09 — IRD-34)
!memory/sonarcloud.md
