{
  "family": "taskmanager-task-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::905418181527:role/taskmanager-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::905418181527:role/taskmanager-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "task-service",
      "image": "905418181527.dkr.ecr.eu-central-1.amazonaws.com/taskmanager-task-service:v2",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 3002,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {"name": "NODE_ENV",   "value": "production"},
        {"name": "PORT",       "value": "3002"},
        {"name": "DB_HOST",    "value": "postgres-task"},
        {"name": "DB_PORT",    "value": "5432"},
        {"name": "DB_NAME",    "value": "tasks"},
        {"name": "DB_USER",    "value": "postgres"},
        {"name": "REDIS_HOST", "value": "redis"},
        {"name": "REDIS_PORT", "value": "6379"}
      ],
      "secrets": [
        {"name": "DB_PASS", "valueFrom": "taskmanager/DB_PASS"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/taskmanager/task-service",
          "awslogs-region":        "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "curl -sf http://localhost:3002/health || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 60
      }
    }
  ]
}
