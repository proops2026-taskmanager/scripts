#!/bin/bash
# ansible/roles/bastion-baseline/templates/kubeconfig.j2
# This template is rendered as a shell script and executed on the bastion.
# It uses the IAM instance profile (no hardcoded credentials) to call
# aws eks update-kubeconfig — the standard AWS-native approach.

set -euo pipefail

aws eks update-kubeconfig \
  --name {{ cluster_name }} \
  --region {{ aws_region }} \
  --kubeconfig /home/ubuntu/.kube/config

echo "kubeconfig written to /home/ubuntu/.kube/config"
kubectl get nodes --no-headers
